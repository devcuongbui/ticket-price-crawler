# Copy file này thành .env và điền thông tin thực tế
# cp .env.example .env

# MongoDB connection URI (bắt buộc)
# Xem hướng dẫn lấy URI tại: https://www.mongodb.com/docs/atlas/driver-connection/
MONGO_URI=your-mongodb-connection-uri-here

# Tên database
DB_NAME=movie_tickets

# Logging: DEBUG | INFO | WARNING
LOG_LEVEL=INFO

# Dump API responses ra ./debug_responses/ (0 = tắt)
DEBUG=0
