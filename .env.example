# Copy file này thành .env và điền thông tin thực tế
# cp .env.example .env

# MongoDB connection URI (bắt buộc)
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/?appName=App
# Local:  mongodb://localhost:27017
MONGO_URI=mongodb+srv://<user>:<password>@<host>/?appName=Cluster0

# Tên database
DB_NAME=movie_tickets

# Logging: DEBUG | INFO | WARNING
LOG_LEVEL=INFO

# Dump API responses ra ./debug_responses/ (0 = tắt)
DEBUG=0
